{
  "name": "journal-app",
  "version": "0.1.0",
  "private": true,
  "description": "A minimal journal app built with Taro, React and TypeScript.",
  "scripts": {
    "dev:weapp": "taro build --type weapp --watch",
    "build:weapp": "taro build --type weapp",
    "dev:h5": "taro build --type h5 --watch",
    "build:h5": "taro build --type h5",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tarojs/components": "3.6.35",
    "@tarojs/helper": "3.6.35",
    "@tarojs/plugin-framework-react": "3.6.35",
    "@tarojs/plugin-platform-h5": "3.6.35",
    "@tarojs/plugin-platform-weapp": "3.6.35",
    "@tarojs/react": "3.6.35",
    "@tarojs/runtime": "3.6.35",
    "@tarojs/shared": "3.6.35",
    "@tarojs/taro": "3.6.35",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@tarojs/cli": "3.6.35",
    "@tarojs/webpack5-runner": "3.6.35",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "babel-preset-taro": "3.6.35",
    "eslint": "^8.57.0",
    "eslint-config-taro": "3.6.35",
    "postcss": "^8.4.35",
    "sass": "^1.69.7",
    "stylelint": "^14.16.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.16.1 <19"
  }
}
